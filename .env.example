# =============================================================
# Autonomous FinOps Engine — Variables de Entorno
# Copia este archivo a '.env' y configura tus valores.
# DO NOT commitear el archivo .env con credenciales reales.
# =============================================================

# ─── GCP Identity ───────────────────────────────────────────
# ID del proyecto de GCP a auditar
GCP_PROJECT_ID=my-finops-project

# Zona específica a escanear (dejar en blanco para escanear TODAS)
GCP_ZONE=

# Región específica a escanear (dejar en blanco para escanear TODAS)
GCP_REGION=

# ─── Modos de Ejecución ─────────────────────────────────────
# true = usa datos de demo sin conectarse a GCP (ideal para pruebas)
DEMO_MODE=false

# ⚠️  PELIGROSO: true = ejecuta `terraform apply -auto-approve` automáticamente
# Solo activar cuando se está SEGURO de querer destruir recursos
AUTO_APPLY=false

# ─── Thresholds de Detección ─────────────────────────────────
# Días que un disco debe llevar desconectado para ser marcado como ocioso
MAX_DISK_AGE_DAYS=30

# Días de antigüedad de un snapshot para ser marcado como obsoleto
MAX_SNAPSHOT_AGE_DAYS=60

# Días en estado TERMINATED para marcar una VM como candidata a remediar
MAX_STOPPED_INSTANCE_DAYS=14
