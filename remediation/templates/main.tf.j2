# ============================================================
# Automatically generated by Autonomous FinOps Engine
# ⚠️  WARNING: These are idle/wasted resources.
# Review carefully before applying. Destruction is irreversible.
# ============================================================

terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
  required_version = ">= 1.5.0"
}

provider "google" {
  project = var.project_id
}

{% for resource in resources %}
# ──────────────────────────────────────────────────────────────
# Resource : {{ resource.id }}
# Type     : {{ resource.type }}
# Location : {{ resource.location }}
# Reason   : {{ resource.reason }}
# Est. Cost: ${{ "%.2f"|format(resource.estimated_monthly_cost_usd) }}/month
# ──────────────────────────────────────────────────────────────

{% if resource.type == 'google_compute_disk' %}
resource "google_compute_disk" "idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}" {
  name    = "{{ resource.id }}"
  zone    = "{{ resource.location }}"
  project = "{{ resource.project }}"
}

import {
  to = google_compute_disk.idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}
  id = "projects/{{ resource.project }}/zones/{{ resource.location }}/disks/{{ resource.id }}"
}

{% elif resource.type == 'google_compute_address' %}
resource "google_compute_address" "idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}" {
  name    = "{{ resource.id }}"
  region  = "{{ resource.location }}"
  project = "{{ resource.project }}"
}

import {
  to = google_compute_address.idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}
  id = "projects/{{ resource.project }}/regions/{{ resource.location }}/addresses/{{ resource.id }}"
}

{% elif resource.type == 'google_compute_instance' %}
resource "google_compute_instance" "idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}" {
  name         = "{{ resource.id }}"
  machine_type = "n1-standard-1"
  zone         = "{{ resource.location }}"
  project      = "{{ resource.project }}"

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-11"
    }
  }
  network_interface {
    network = "default"
  }
}

import {
  to = google_compute_instance.idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}
  id = "projects/{{ resource.project }}/zones/{{ resource.location }}/instances/{{ resource.id }}"
}

{% elif resource.type == 'google_compute_snapshot' %}
resource "google_compute_snapshot" "idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}" {
  name    = "{{ resource.id }}"
  project = "{{ resource.project }}"
  source_disk = "placeholder"  # Actualizar con el disco fuente si se conoce
}

import {
  to = google_compute_snapshot.idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}
  id = "projects/{{ resource.project }}/global/snapshots/{{ resource.id }}"
}

{% elif resource.type == 'google_storage_bucket' %}
resource "google_storage_bucket" "idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}" {
  name     = "{{ resource.id }}"
  location = "{{ resource.location | upper }}"
  project  = "{{ resource.project }}"
}

import {
  to = google_storage_bucket.idle_{{ resource.id | replace('-', '_') | replace('.', '_') }}
  id = "{{ resource.id }}"
}

{% elif resource.type == 'google_compute_firewall' %}
resource "google_compute_firewall" "risky_{{ resource.id | replace('-', '_') | replace('.', '_') }}" {
  name    = "{{ resource.id }}"
  network = "default"
  project = "{{ resource.project }}"

  # ⚠️ Revisar y restringir las fuentes de esta regla antes de aplicar
  allow {
    protocol = "tcp"
  }
}

import {
  to = google_compute_firewall.risky_{{ resource.id | replace('-', '_') | replace('.', '_') }}
  id = "projects/{{ resource.project }}/global/firewalls/{{ resource.id }}"
}

{% endif %}
{% endfor %}
