provider "google" {
  project = var.project_id
}

{% for resource in resources %}
# Target: {{ resource.id }}
# Reason: {{ resource.reason }}
{% if resource.type == 'google_compute_disk' %}
resource "google_compute_disk" "idle_disk_{{ resource.id | replace('-', '_') }}" {
  name    = "{{ resource.id }}"
  zone    = "{{ resource.location }}"
  project = "{{ resource.project }}"
  # Se pueden agregar dependencias de lifecycle (prevent_destroy) temporalmente si se requiere validación manual.
}

import {
  to = google_compute_disk.idle_disk_{{ resource.id | replace('-', '_') }}
  id = "projects/{{ resource.project }}/zones/{{ resource.location }}/disks/{{ resource.id }}"
}
{% elif resource.type == 'google_compute_address' %}
resource "google_compute_address" "idle_ip_{{ resource.id | replace('-', '_') }}" {
  name    = "{{ resource.id }}"
  region  = "{{ resource.location }}"
  project = "{{ resource.project }}"
}

import {
  to = google_compute_address.idle_ip_{{ resource.id | replace('-', '_') }}
  id = "projects/{{ resource.project }}/regions/{{ resource.location }}/addresses/{{ resource.id }}"
}
{% endif %}

{% endfor %}
